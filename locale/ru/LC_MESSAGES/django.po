# Django auth built-in strings (override / fill gaps in Django's own catalog)
msgid "Required. 150 characters or fewer. Letters, digits and @/./+/-/_ only."
msgstr "Обязательно. Не более 150 символов. Только буквы, цифры и @/./+/-/_."

msgid "Your password can’t be too similar to your other personal information."
msgstr "Пароль не должен быть слишком похож на другие ваши личные данные."

msgid "Your password must contain at least 8 characters."
msgstr "Пароль должен содержать не менее 8 символов."

msgid "Your password can’t be a commonly used password."
msgstr "Пароль не должен быть слишком распространённым."

msgid "Your password can’t be entirely numeric."
msgstr "Пароль не может состоять только из цифр."

msgid "Password confirmation"
msgstr "Подтверждение пароля"

msgid "Enter the same password as before, for verification."
msgstr "Введите тот же пароль, что и выше — для проверки."
