# Django auth built-in strings (UZ translations are partial in Django itself)
msgid "Password"
msgstr "Parol"

msgid "username"
msgstr "foydalanuvchi nomi"

msgid "password"
msgstr "parol"

msgid "email address"
msgstr "elektron pochta"

msgid "Required. 150 characters or fewer. Letters, digits and @/./+/-/_ only."
msgstr "Majburiy. 150 ta belgidan oshmasligi kerak. Faqat harflar, raqamlar va @/./+/-/_ ruxsat etiladi."

msgid "Your password can’t be too similar to your other personal information."
msgstr "Parolingiz boshqa shaxsiy ma'lumotlaringizga juda o'xshamasligi kerak."

msgid "Your password must contain at least 8 characters."
msgstr "Parolingiz kamida 8 ta belgidan iborat bo'lishi kerak."

#, python-format
msgid "Your password must contain at least %(min_length)d character."
msgid_plural "Your password must contain at least %(min_length)d characters."
msgstr[0] "Parolingiz kamida %(min_length)d ta belgidan iborat bo'lishi kerak."
msgstr[1] "Parolingiz kamida %(min_length)d ta belgidan iborat bo'lishi kerak."

msgid "Your password can’t be a commonly used password."
msgstr "Parolingiz keng tarqalgan parol bo'lmasligi kerak."

msgid "Your password can’t be entirely numeric."
msgstr "Parolingiz faqat raqamlardan iborat bo'lmasligi kerak."

msgid "Password confirmation"
msgstr "Parolni tasdiqlash"

msgid "Enter the same password as before, for verification."
msgstr "Tekshirish uchun avvalgi parolni qaytadan kiriting."

msgid "A user with that username already exists."
msgstr "Bu foydalanuvchi nomi allaqachon mavjud."

msgid "The two password fields didn’t match."
msgstr "Ikkala parol maydoni mos kelmadi."

msgid "Please enter a correct username and password. Note that both fields may be case-sensitive."
msgstr "Iltimos, to'g'ri foydalanuvchi nomi va parolni kiriting. E'tibor bering: ikkala maydon ham katta-kichik harflarga sezgir."

msgid "This account is inactive."
msgstr "Bu hisob faol emas."

msgid "Logged out"
msgstr "Tizimdan chiqildi"
